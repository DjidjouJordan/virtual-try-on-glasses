APP_NAME=DPGlassess
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Base de données PostgreSQL
# En local (Docker/Sail) : DB_HOST=pgsql (nom du service dans compose.yaml)
# Sur Railway : utiliser DATABASE_URL fournie automatiquement OU les vars ci-dessous
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dpglassess
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_SSLMODE=prefer
# Sur Railway, vous pouvez aussi utiliser l'URL complète à la place des vars ci-dessus :
# DATABASE_URL=postgresql://user:password@host:5432/dbname

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dpglassess.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Stockage fichiers (images, modèles 3D)
# En local : FILESYSTEM_DISK=public (dossier storage/)
# En production : basculer sur S3/R2 et remplir ces variables
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# CamPay (paiement Mobile Money)
# ---------------------------------------------------------------------------
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_USERNAME=
CAMPAY_PASSWORD=
CAMPAY_PERMANENT_TOKEN=
CAMPAY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Frontend (CORS)
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

VITE_APP_NAME="${APP_NAME}"
